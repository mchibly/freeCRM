# ─── Environment ───
NODE_ENV=development

# ─── API ───
API_PORT=3001
API_PREFIX=api
API_CORS_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL) ───
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=freecrm
DATABASE_USER=freecrm
DATABASE_PASSWORD=freecrm_dev_password
DATABASE_SSL=false

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Keycloak (IAM) ───
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=freecrm
KEYCLOAK_CLIENT_ID=freecrm-api
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── MinIO (S3-compatible Storage) ───
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=freecrm-files
MINIO_USE_SSL=false

# ─── Frontend (Next.js) ───
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=freecrm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=freecrm-web
